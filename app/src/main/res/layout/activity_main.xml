<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#16213e">

        <TextView
            android:id="@+id/tvMyAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My address: not connected"
            android:textColor="#00d4ff"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Spinner
                android:id="@+id/spinnerDevices"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="#0f3460"
                android:paddingStart="8dp"/>

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Connect"
                android:textSize="12sp"
                android:backgroundTint="#00d4ff"
                android:textColor="#1a1a2e"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnTabChat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="?? Chat"
            android:textSize="13sp"
            android:backgroundTint="#00d4ff"
            android:textColor="#1a1a2e"/>

        <Button
            android:id="@+id/btnTabAnnounces"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="?? Network"
            android:textSize="13sp"
            android:backgroundTint="#0f3460"
            android:textColor="#ffffff"/>
    </LinearLayout>

    <!-- Chat panel -->
    <LinearLayout
        android:id="@+id/panelChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Dest address input -->
        <EditText
            android:id="@+id/etDestHash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Destination address (hex)"
            android:textColorHint="#666"
            android:textColor="#ffffff"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="#0f3460"
            android:padding="8dp"
            android:singleLine="true"
            android:inputType="textNoSuggestions"/>

        <!-- Messages list -->
        <ScrollView
            android:id="@+id/scrollChat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/chatContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </ScrollView>

        <!-- Message input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#16213e">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Type a message..."
                android:textColorHint="#666"
                android:textColor="#ffffff"
                android:background="#0f3460"
                android:padding="8dp"
                android:inputType="textMultiLine"/>

            <Button
                android:id="@+id/btnSend"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Send"
                android:backgroundTint="#00d4ff"
                android:textColor="#1a1a2e"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Announces panel -->
    <ScrollView
        android:id="@+id/panelAnnounces"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/announcesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

</LinearLayout>
